---
import { siteConfig } from "../../config/site";
import { Route, User, MessageSquare } from "@lucide/astro";
import type { Translations } from "../../i18n/types";

interface Props {
  t: Translations;
  defaultTo?: string;
  id?: string;
}

const { t, defaultTo = "", id = "reservation-form" } = Astro.props;
const whatsappNumber = siteConfig.whatsapp.number;

const fieldLabels = JSON.stringify({
  nameField: t.form.nameField,
  fromField: t.form.fromField,
  toField: t.form.toField,
  dateField: t.form.dateField,
  timeField: t.form.timeField,
  phoneField: t.form.phoneField,
  emailField: t.form.emailField,
  passengersField: t.form.passengersField,
  luggageField: t.form.luggageField,
  flightField: t.form.flightField,
  messageField: t.form.messageField,
  datePastError: t.form.datePastError,
  phoneInvalidError: t.form.phoneInvalidError,
  whatsappGreeting: t.form.whatsappGreeting,
  whatsappClosing: t.form.whatsappClosing,
});

const inputClass =
  "w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-taxi-400 focus:border-transparent";
---

<form id={id} class="rounded-2xl bg-white border border-gray-100 p-6 sm:p-8 space-y-8" data-whatsapp-number={whatsappNumber} data-field-labels={fieldLabels}>
  <!-- Ride Details -->
  <fieldset>
    <legend class="text-lg font-semibold text-dark mb-4 flex items-center gap-2">
      <Route class="h-5 w-5 text-taxi-500" />
      {t.form.groupRide}
    </legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for={`${id}-from`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.fromLabel}</label>
        <input
          type="text"
          id={`${id}-from`}
          name="from"
          required
          autocomplete="off"
          class={inputClass}
          placeholder={t.form.fromPlaceholder}
        />
        <input type="hidden" id={`${id}-from-place-id`} name="from_place_id" />
      </div>
      <div>
        <label for={`${id}-to`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.toLabel}</label>
        <input
          type="text"
          id={`${id}-to`}
          name="to"
          required
          autocomplete="off"
          value={defaultTo}
          class={inputClass}
          placeholder={t.form.toPlaceholder}
        />
        <input type="hidden" id={`${id}-to-place-id`} name="to_place_id" />
      </div>
      <div>
        <label for={`${id}-date`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.dateLabel}</label>
        <input
          type="date"
          id={`${id}-date`}
          name="date"
          required
          class={inputClass}
        />
      </div>
      <div>
        <label for={`${id}-time`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.timeLabel}</label>
        <input
          type="time"
          id={`${id}-time`}
          name="time"
          required
          class={inputClass}
        />
      </div>
      <div>
        <label for={`${id}-passengers`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.passengersLabel}</label>
        <select
          id={`${id}-passengers`}
          name="passengers"
          required
          class={inputClass}
        >
          {[1, 2, 3, 4].map((n) => (
            <option value={n}>{n}</option>
          ))}
        </select>
      </div>
      <div>
        <label for={`${id}-luggage`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.luggageLabel}</label>
        <select
          id={`${id}-luggage`}
          name="luggage"
          required
          class={inputClass}
        >
          {[0, 1, 2, 3, 4].map((n) => (
            <option value={n}>{n}</option>
          ))}
        </select>
      </div>
      <div>
        <label for={`${id}-flight`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.flightLabel}</label>
        <input
          type="text"
          id={`${id}-flight`}
          name="flight"
          class={inputClass}
          placeholder={t.form.flightPlaceholder}
        />
      </div>
    </div>
  </fieldset>

  <hr class="border-gray-200" />

  <!-- Personal Details -->
  <fieldset>
    <legend class="text-lg font-semibold text-dark mb-4 flex items-center gap-2">
      <User class="h-5 w-5 text-taxi-500" />
      {t.form.groupPersonal}
    </legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for={`${id}-name`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.nameLabel}</label>
        <input
          type="text"
          id={`${id}-name`}
          name="name"
          required
          class={inputClass}
          placeholder={t.form.namePlaceholder}
        />
      </div>
      <div>
        <label for={`${id}-phone`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.phoneLabel}</label>
        <input
          type="tel"
          id={`${id}-phone`}
          name="phone"
          required
          inputmode="tel"
          class={inputClass}
          placeholder={t.form.phonePlaceholder}
        />
      </div>
      <div class="sm:col-span-2">
        <label for={`${id}-email`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.emailLabel}</label>
        <input
          type="email"
          id={`${id}-email`}
          name="email"
          class={inputClass}
          placeholder={t.form.emailPlaceholder}
        />
      </div>
    </div>
  </fieldset>

  <hr class="border-gray-200" />

  <!-- Additional Info -->
  <fieldset>
    <legend class="text-lg font-semibold text-dark mb-4 flex items-center gap-2">
      <MessageSquare class="h-5 w-5 text-taxi-500" />
      {t.form.groupAdditional}
    </legend>
    <div>
      <label for={`${id}-message`} class="block text-sm font-medium text-gray-700 mb-1">{t.form.messageLabel}</label>
      <textarea
        id={`${id}-message`}
        name="message"
        rows="3"
        class:list={[inputClass, "resize-none"]}
        placeholder={t.form.messagePlaceholder}
      ></textarea>
    </div>
  </fieldset>

  <p class="text-xs text-gray-500 text-center">{t.form.tariffNote}</p>

  <button
    type="submit"
    class="w-full rounded-full bg-taxi-400 px-6 py-3.5 font-semibold text-dark hover:bg-taxi-500 transition-colors text-base cursor-pointer"
  >
    {t.form.submit}
  </button>
</form>

<style is:global>
  .pac-container {
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    font-family: "Inter", sans-serif;
    font-size: 0.875rem;
    margin-top: 4px;
    z-index: 9999;
  }
  .pac-item {
    padding: 8px 12px;
    cursor: pointer;
    border-top: 1px solid #f3f4f6;
  }
  .pac-item:first-child {
    border-top: none;
  }
  .pac-item:hover,
  .pac-item-selected {
    background-color: #fef9c3;
  }
  .pac-icon {
    display: none;
  }
  .pac-item-query {
    font-size: 0.875rem;
    color: #1f2937;
  }
  .pac-matched {
    font-weight: 600;
  }

  /* intl-tel-input overrides */
  .iti {
    width: 100%;
  }
  .iti .iti__search-input {
    font-size: 0.875rem;
  }
  .iti .iti__dropdown-content {
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    z-index: 10000;
  }
  .iti .iti__country-container {
    border-radius: 0.5rem 0 0 0.5rem;
  }
</style>

<script>
  import intlTelInput from "intl-tel-input";
  import "intl-tel-input/styles";

  document.querySelectorAll<HTMLFormElement>("form[data-whatsapp-number]").forEach((form) => {
    const id = form.id;
    const whatsappNumber = form.dataset.whatsappNumber;
    const labels = JSON.parse(form.dataset.fieldLabels || "{}");

    // Set min date to today
    const dateInput = document.getElementById(`${id}-date`) as HTMLInputElement | null;
    if (dateInput) {
      const today = new Date().toISOString().split("T")[0];
      dateInput.setAttribute("min", today);
    }

    // Initialize intl-tel-input on the phone input
    const phoneInput = document.getElementById(`${id}-phone`) as HTMLInputElement | null;
    let iti: ReturnType<typeof intlTelInput> | null = null;
    if (phoneInput) {
      iti = intlTelInput(phoneInput, {
        initialCountry: "de",
        countryOrder: ["de", "at", "ch", "tr"],
        separateDialCode: true,
        countrySearch: true,
        loadUtils: () => import("intl-tel-input/utils"),
      });

      phoneInput.addEventListener("input", () => {
        phoneInput.setCustomValidity("");
      });
      phoneInput.addEventListener("invalid", () => {
        phoneInput.setCustomValidity(labels.phoneInvalidError);
      });
    }

    // Google Places Autocomplete
    function initAutocomplete() {
      if (typeof google === "undefined" || !google.maps || !google.maps.places) {
        setTimeout(initAutocomplete, 200);
        return;
      }

      const munichBounds = new google.maps.LatLngBounds(
        new google.maps.LatLng(47.9, 11.2),
        new google.maps.LatLng(48.4, 12.0)
      );

      const options = {
        bounds: munichBounds,
        componentRestrictions: { country: "de" },
        fields: ["formatted_address", "place_id"],
        types: ["geocode", "establishment"],
      };

      const fromInput = document.getElementById(`${id}-from`) as HTMLInputElement | null;
      const toInput = document.getElementById(`${id}-to`) as HTMLInputElement | null;

      if (fromInput) {
        const fromAc = new google.maps.places.Autocomplete(fromInput, options);
        fromAc.addListener("place_changed", () => {
          const place = fromAc.getPlace();
          if (place.formatted_address) fromInput.value = place.formatted_address;
          const hidden = document.getElementById(`${id}-from-place-id`) as HTMLInputElement | null;
          if (hidden && place.place_id) hidden.value = place.place_id;
        });
      }

      if (toInput) {
        const toAc = new google.maps.places.Autocomplete(toInput, options);
        toAc.addListener("place_changed", () => {
          const place = toAc.getPlace();
          if (place.formatted_address) toInput.value = place.formatted_address;
          const hidden = document.getElementById(`${id}-to-place-id`) as HTMLInputElement | null;
          if (hidden && place.place_id) hidden.value = place.place_id;
        });
      }
    }

    initAutocomplete();

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Validate phone using intl-tel-input
      if (iti) {
        await iti.promise;
        if (!iti.isValidNumber()) {
          phoneInput!.setCustomValidity(labels.phoneInvalidError);
          phoneInput!.reportValidity();
          phoneInput!.addEventListener("input", () => phoneInput!.setCustomValidity(""), { once: true });
          return;
        }
      }

      const data = new FormData(form);

      // Validate date is not in the past
      const rawDate = data.get("date") as string | null;
      if (rawDate) {
        const today = new Date().toISOString().split("T")[0];
        if (rawDate < today) {
          const dateEl = document.getElementById(`${id}-date`) as HTMLInputElement | null;
          if (dateEl) {
            dateEl.setCustomValidity(labels.datePastError);
            dateEl.reportValidity();
            dateEl.addEventListener("input", () => dateEl.setCustomValidity(""), { once: true });
          }
          return;
        }
      }

      // Format date as DD.MM.YYYY
      let formattedDate = rawDate;
      if (rawDate) {
        const [y, m, d] = rawDate.split("-");
        formattedDate = `${d}.${m}.${y}`;
      }

      // Get full international phone number
      const fullPhoneNumber = iti ? iti.getNumber() : data.get("phone");

      const fromPlaceId = data.get("from_place_id");
      const toPlaceId = data.get("to_place_id");
      const fromLink = fromPlaceId ? `https://www.google.com/maps/search/?api=1&query=Google&query_place_id=${fromPlaceId}` : "";
      const toLink = toPlaceId ? `https://www.google.com/maps/search/?api=1&query=Google&query_place_id=${toPlaceId}` : "";

      const lines: string[] = [
        labels.whatsappGreeting,
        "",
        `📍 ${labels.fromField}:`,
        data.get("from") as string,
      ];
      if (fromLink) lines.push(fromLink);

      lines.push(
        "",
        `📍 ${labels.toField}:`,
        data.get("to") as string,
      );
      if (toLink) lines.push(toLink);

      lines.push(
        "",
        `📅 ${labels.dateField}: ${formattedDate}`,
        `⏰ ${labels.timeField}: ${data.get("time")}`,
        "",
        `👤 ${labels.passengersField}: ${data.get("passengers")}`,
        `🧳 ${labels.luggageField}: ${data.get("luggage")}`,
      );

      const flight = data.get("flight");
      if (flight) lines.push("", `✈️ ${labels.flightField}: ${flight}`);

      lines.push(
        "",
        `👤 ${labels.nameField}: ${data.get("name")}`,
        `📞 ${labels.phoneField}: ${fullPhoneNumber}`,
      );

      const email = data.get("email");
      if (email) lines.push(`📧 ${labels.emailField}: ${email}`);

      const message = data.get("message");
      if (message) lines.push("", `💬 ${labels.messageField}: ${message}`);

      lines.push("", labels.whatsappClosing);

      window.open(
        `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(lines.join("\n"))}`,
        "_blank"
      );
    });
  });
</script>
