---
import { CreditCard, Plane, Briefcase, Route, ShieldCheck, Smartphone, Wallet } from "@lucide/astro";
import { siteConfig } from "../../config/site";
import type { Translations } from "../../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const whatsappUrl = `https://wa.me/${siteConfig.whatsapp.number}?text=${encodeURIComponent(t.whatsapp.message)}`;
---

<section id="hero" class="relative min-h-screen flex items-center bg-dark pt-16">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img src="/Hero.png" alt="" class="h-full w-full object-cover" />
    <div class="absolute inset-0 bg-dark/70"></div>
    <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-dark via-dark/60 to-transparent md:hidden"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 md:py-20 w-full">
    <div class="max-w-3xl">
      <p class="hidden md:block text-taxi-400 font-semibold text-sm uppercase tracking-wider mb-4">
        {t.hero.tagline} {siteConfig.address.city}
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight">
        {t.hero.headline} {siteConfig.address.city}.
        <span class="text-taxi-400 hidden md:inline">{t.hero.headlineHighlight}</span>
        <span class="text-taxi-400 md:hidden">{t.hero.headlineHighlightShort}</span>
      </h1>

      <!-- Desktop: description paragraph -->
      <p class="hidden md:block mt-6 text-xl font-semibold text-gray-200 max-w-xl" set:html={t.hero.description} />

      <!-- Mobile: service icon rows -->
      <div class="flex flex-col gap-2 mt-4 md:hidden">
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-full bg-taxi-400/20">
            <Plane class="h-5 w-5 text-taxi-400" />
          </div>
          <div>
            <span class="text-white font-semibold text-sm">{t.hero.featureAirport}</span>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-full bg-taxi-400/20">
            <Route class="h-5 w-5 text-taxi-400" />
          </div>
          <div>
            <span class="text-white font-semibold text-sm">{t.hero.featureLongDistance}</span>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-full bg-taxi-400/20">
            <Briefcase class="h-5 w-5 text-taxi-400" />
          </div>
          <div>
            <span class="text-white font-semibold text-sm">{t.hero.featureBusiness}</span>
          </div>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="mt-5 md:mt-10 flex flex-col sm:flex-row gap-3 md:gap-4">
        <a
          href="/#reservation"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-taxi-400 px-8 py-4 text-lg font-bold text-dark hover:bg-taxi-500 transition-colors"
        >
          {t.hero.ctaReserve}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 rounded-full bg-green-500 px-8 py-4 text-white hover:bg-green-600 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6 shrink-0">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
          </svg>
          <div class="text-left">
            <span class="font-bold text-lg block leading-tight">{t.hero.whatsappCta}</span>
            <span class="text-sm text-white/80 md:hidden">{t.hero.whatsappSubtitle}</span>
          </div>
        </a>
      </div>

      <!-- Payment card -->
      <div class="mt-4 md:mt-8">
        <!-- Mobile layout -->
        <div class="md:hidden rounded-xl bg-dark/60 backdrop-blur border border-gray-700 p-4">
          <div class="flex items-center gap-3 mb-3">
            <CreditCard class="h-6 w-6 text-taxi-400 shrink-0" />
            <div>
              <span class="text-white font-bold text-sm block">{t.hero.paymentCardTitle}</span>
              <span class="text-gray-400 text-xs">{t.hero.paymentCardSubtitle}</span>
            </div>
          </div>
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center justify-center h-9 px-3 rounded-md bg-white border border-gray-600">
              <img src="/Visa.png" alt="Visa" class="h-4 w-auto" />
            </div>
            <div class="flex items-center justify-center h-9 px-3 rounded-md bg-white border border-gray-600">
              <img src="/Mastercard.png" alt="Mastercard" class="h-5 w-auto" />
            </div>
            <div class="flex items-center justify-center h-9 px-3 rounded-md bg-white border border-gray-600">
              <img src="/Maestro.svg" alt="Maestro" class="h-4 w-auto" />
            </div>
            <div class="flex items-center justify-center h-9 px-3 rounded-md bg-white border border-gray-600">
              <img src="/EC.svg" alt="EC" class="h-5 w-auto" />
            </div>
            <div class="flex items-center justify-center h-9 px-3 rounded-md bg-white border border-gray-600">
              <img src="/ApplePay.png" alt="Apple Pay" class="h-4 w-auto" />
            </div>
          </div>
        </div>
        <!-- Desktop layout -->
        <div class="hidden md:inline-flex items-center gap-4 rounded-full bg-dark/50 backdrop-blur border border-gray-700 px-5 py-3">
          <CreditCard class="h-5 w-5 text-taxi-400 shrink-0" />
          <span class="text-white font-semibold text-sm">{t.hero.paymentCardTitle}</span>
          <span class="text-gray-500">|</span>
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center h-8 px-2.5 rounded-md bg-white">
              <img src="/Visa.png" alt="Visa" class="h-3.5 w-auto" />
            </div>
            <div class="flex items-center justify-center h-8 px-2.5 rounded-md bg-white">
              <img src="/Mastercard.png" alt="Mastercard" class="h-4.5 w-auto" />
            </div>
            <div class="flex items-center justify-center h-8 px-2.5 rounded-md bg-white">
              <img src="/Maestro.svg" alt="Maestro" class="h-3.5 w-auto" />
            </div>
            <div class="flex items-center justify-center h-8 px-2.5 rounded-md bg-white">
              <img src="/EC.svg" alt="EC" class="h-4.5 w-auto" />
            </div>
            <div class="flex items-center justify-center h-8 px-2.5 rounded-md bg-white">
              <img src="/ApplePay.png" alt="Apple Pay" class="h-3.5 w-auto" />
            </div>
          </div>
        </div>
      </div>

      <!-- Trust bar (mobile) -->
      <div class="mt-4 flex items-center justify-center gap-2 text-sm text-gray-400 md:hidden">
        <ShieldCheck class="h-4 w-4 text-taxi-400" />
        {t.hero.trustItems.map((item, i) => (
          <>
            <span>{item}</span>
            {i < t.hero.trustItems.length - 1 && <span>•</span>}
          </>
        ))}
      </div>
    </div>
  </div>
</section>
