---
import { Star, ChevronLeft, ChevronRight } from "@lucide/astro";
import type { Translations } from "../../i18n/types";
import { reviewsConfig } from "../../config/reviews";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const { overallRating, totalReviews, googleMapsUrl, reviews } = reviewsConfig;
---

<section id="reviews" class="py-20 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-dark text-center mb-10">
      {t.reviews.title}
    </h2>

    <div class="rounded-2xl bg-gray-50 p-6 sm:p-8">
      <!-- Header: Google Reviews + Rating + CTA -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <!-- Google logo -->
            <svg class="h-6" viewBox="0 0 272 92" xmlns="http://www.w3.org/2000/svg">
              <path d="M115.75 47.18c0 12.77-9.99 22.18-22.25 22.18s-22.25-9.41-22.25-22.18C71.25 34.32 81.24 25 93.5 25s22.25 9.32 22.25 22.18zm-9.74 0c0-7.98-5.79-13.44-12.51-13.44S80.99 39.2 80.99 47.18c0 7.9 5.79 13.44 12.51 13.44s12.51-5.55 12.51-13.44z" fill="#EA4335"/>
              <path d="M163.75 47.18c0 12.77-9.99 22.18-22.25 22.18s-22.25-9.41-22.25-22.18C119.25 34.32 129.24 25 141.5 25s22.25 9.32 22.25 22.18zm-9.74 0c0-7.98-5.79-13.44-12.51-13.44s-12.51 5.46-12.51 13.44c0 7.9 5.79 13.44 12.51 13.44s12.51-5.55 12.51-13.44z" fill="#FBBC05"/>
              <path d="M209.75 26.34v39.82c0 16.38-9.66 23.07-21.08 23.07-10.75 0-17.22-7.19-19.66-13.07l8.48-3.53c1.51 3.61 5.21 7.87 11.17 7.87 7.31 0 11.84-4.51 11.84-13v-3.19h-.34c-2.18 2.69-6.38 5.04-11.68 5.04-11.09 0-21.25-9.66-21.25-22.09 0-12.52 10.16-22.26 21.25-22.26 5.29 0 9.49 2.35 11.68 4.96h.34v-3.61h9.25zm-8.56 20.92c0-7.81-5.21-13.52-11.84-13.52-6.72 0-12.35 5.71-12.35 13.52 0 7.73 5.63 13.36 12.35 13.36 6.63 0 11.84-5.63 11.84-13.36z" fill="#4285F4"/>
              <path d="M225 3v65h-9.5V3h9.5z" fill="#34A853"/>
              <path d="M262.02 54.48l7.56 5.04c-2.44 3.61-8.32 9.83-18.48 9.83-12.6 0-22.01-9.74-22.01-22.18 0-13.19 9.49-22.18 20.92-22.18 11.51 0 17.14 9.16 18.98 14.11l1.01 2.52-29.65 12.28c2.27 4.45 5.8 6.72 10.75 6.72 4.96 0 8.4-2.44 10.92-6.14zm-23.27-7.98l19.82-8.23c-1.09-2.77-4.37-4.7-8.23-4.7-4.95 0-11.84 4.37-11.59 12.93z" fill="#EA4335"/>
              <path d="M35.29 41.19V32H67.4c.32 1.68.48 3.69.48 5.86 0 7.27-1.99 16.27-8.39 22.67C53.28 66.95 45.32 69.36 35.3 69.36 17.14 69.36 2 54.89 2 36.73S17.14 4.1 35.3 4.1c10.1 0 17.31 3.95 22.69 9.08l-6.39 6.39c-3.86-3.61-9.08-6.42-16.3-6.42-13.31 0-23.72 10.74-23.72 23.58s10.41 23.58 23.72 23.58c8.65 0 13.56-3.47 16.71-6.63 2.56-2.56 4.24-6.22 4.89-11.22H35.29z" fill="#4285F4"/>
            </svg>
            <span class="text-lg font-semibold text-gray-700">Reviews</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-2xl font-bold text-dark">{overallRating}</span>
            <div class="flex gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <Star
                  class={`h-5 w-5 ${i < Math.round(overallRating) ? "fill-yellow-400 text-yellow-400" : "fill-gray-300 text-gray-300"}`}
                />
              ))}
            </div>
            <span class="text-sm text-gray-500">({totalReviews})</span>
          </div>
        </div>

        <a
          href={googleMapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700 transition-colors whitespace-nowrap"
        >
          {t.reviews.reviewUs}
        </a>
      </div>

      <!-- Review Cards Carousel -->
      <div class="relative">
        <div
          id="reviews-carousel"
          class="flex gap-4 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 px-10 sm:px-12 -mx-10 sm:-mx-12"
          style="scrollbar-width: none; -ms-overflow-style: none;"
        >
          {reviews.map((review) => (
            <div class="flex-shrink-0 w-[calc(100%-4rem)] sm:w-72 snap-center sm:snap-start rounded-xl bg-white border border-gray-200 p-5">
              <div class="flex items-center gap-3 mb-3">
                <!-- Avatar -->
                {review.initial ? (
                  <div class="relative flex-shrink-0">
                    <div class="h-10 w-10 rounded-full bg-purple-600 flex items-center justify-center text-white font-semibold text-sm">
                      {review.initial}
                    </div>
                    <svg class="absolute -bottom-0.5 -right-0.5 h-4 w-4" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="12" fill="white"/>
                      <path d="M12.545 10.239v3.821h5.445c-.712 2.315-2.647 3.972-5.445 3.972a6.033 6.033 0 110-12.064c1.498 0 2.866.549 3.921 1.453l2.814-2.814A9.969 9.969 0 0012.545 2C7.021 2 2.543 6.477 2.543 12s4.478 10 10.002 10c8.396 0 10.249-7.85 9.426-11.748l-9.426-.013z" fill="#4285F4"/>
                      <path d="M12.545 10.239v3.821h5.445c-.712 2.315-2.647 3.972-5.445 3.972a6.033 6.033 0 01-5.21-2.997l-3.297 2.54A9.98 9.98 0 0012.545 22c5.524 0 10.002-4.477 10.002-10 0-.585-.049-1.167-.146-1.748l-9.856-.013z" fill="#34A853"/>
                      <path d="M7.335 14.035a6.043 6.043 0 010-4.07l-3.297-2.54a9.972 9.972 0 000 9.15l3.297-2.54z" fill="#FBBC05"/>
                      <path d="M12.545 5.936c1.498 0 2.866.549 3.921 1.453l2.814-2.814A9.969 9.969 0 0012.545 2a9.98 9.98 0 00-8.507 4.725l3.297 2.54a6.033 6.033 0 015.21-3.329z" fill="#EA4335"/>
                    </svg>
                  </div>
                ) : (
                  <div class="relative flex-shrink-0">
                    <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center text-gray-600 font-semibold text-sm">
                      {review.name.charAt(0)}
                    </div>
                    <svg class="absolute -bottom-0.5 -right-0.5 h-4 w-4" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="12" fill="white"/>
                      <path d="M12.545 10.239v3.821h5.445c-.712 2.315-2.647 3.972-5.445 3.972a6.033 6.033 0 110-12.064c1.498 0 2.866.549 3.921 1.453l2.814-2.814A9.969 9.969 0 0012.545 2C7.021 2 2.543 6.477 2.543 12s4.478 10 10.002 10c8.396 0 10.249-7.85 9.426-11.748l-9.426-.013z" fill="#4285F4"/>
                      <path d="M12.545 10.239v3.821h5.445c-.712 2.315-2.647 3.972-5.445 3.972a6.033 6.033 0 01-5.21-2.997l-3.297 2.54A9.98 9.98 0 0012.545 22c5.524 0 10.002-4.477 10.002-10 0-.585-.049-1.167-.146-1.748l-9.856-.013z" fill="#34A853"/>
                      <path d="M7.335 14.035a6.043 6.043 0 010-4.07l-3.297-2.54a9.972 9.972 0 000 9.15l3.297-2.54z" fill="#FBBC05"/>
                      <path d="M12.545 5.936c1.498 0 2.866.549 3.921 1.453l2.814-2.814A9.969 9.969 0 0012.545 2a9.98 9.98 0 00-8.507 4.725l3.297 2.54a6.033 6.033 0 015.21-3.329z" fill="#EA4335"/>
                    </svg>
                  </div>
                )}
                <div class="min-w-0">
                  <div class="flex items-center gap-1">
                    <p class="font-semibold text-sm text-dark truncate">{review.name}</p>
                    <svg class="h-4 w-4 flex-shrink-0 text-blue-500" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                    </svg>
                  </div>
                  <p class="text-xs text-gray-400">{review.date}</p>
                </div>
              </div>
              <div class="flex gap-0.5 mb-2">
                {Array.from({ length: 5 }).map((_, i) => (
                  <Star
                    class={`h-4 w-4 ${i < review.rating ? "fill-yellow-400 text-yellow-400" : "fill-gray-300 text-gray-300"}`}
                  />
                ))}
              </div>
              <p class="text-sm text-gray-700 leading-relaxed">{review.text}</p>
            </div>
          ))}
        </div>

        <!-- Navigation arrows -->
        <button
          id="reviews-prev"
          class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1 sm:-translate-x-3 flex h-9 w-9 sm:h-10 sm:w-10 items-center justify-center rounded-full bg-white border border-gray-200 shadow-md hover:bg-gray-50 transition-all disabled:opacity-30 disabled:cursor-default disabled:hover:bg-white"
          aria-label="Previous reviews"
          disabled
        >
          <ChevronLeft class="h-5 w-5 text-gray-600" />
        </button>
        <button
          id="reviews-next"
          class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1 sm:translate-x-3 flex h-9 w-9 sm:h-10 sm:w-10 items-center justify-center rounded-full bg-white border border-gray-200 shadow-md hover:bg-gray-50 transition-all disabled:opacity-30 disabled:cursor-default disabled:hover:bg-white"
          aria-label="Next reviews"
        >
          <ChevronRight class="h-5 w-5 text-gray-600" />
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  #reviews-carousel::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const carousel = document.getElementById("reviews-carousel");
  const prevBtn = document.getElementById("reviews-prev") as HTMLButtonElement | null;
  const nextBtn = document.getElementById("reviews-next") as HTMLButtonElement | null;

  if (carousel && prevBtn && nextBtn) {
    function getScrollAmount() {
      const card = carousel!.querySelector<HTMLElement>(":scope > div");
      return card ? card.offsetWidth + 16 : 288;
    }

    function updateArrows() {
      if (!carousel || !prevBtn || !nextBtn) return;
      const atStart = carousel.scrollLeft <= 0;
      const atEnd = carousel.scrollLeft + carousel.clientWidth >= carousel.scrollWidth - 1;
      prevBtn.disabled = atStart;
      nextBtn.disabled = atEnd;
    }

    nextBtn.addEventListener("click", () => {
      carousel.scrollBy({ left: getScrollAmount(), behavior: "smooth" });
    });

    prevBtn.addEventListener("click", () => {
      carousel.scrollBy({ left: -getScrollAmount(), behavior: "smooth" });
    });

    carousel.addEventListener("scroll", updateArrows);
    window.addEventListener("resize", updateArrows);
    updateArrows();
  }
</script>
