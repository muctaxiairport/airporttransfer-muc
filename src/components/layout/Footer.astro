---
import { Phone } from "@lucide/astro";
import { siteConfig } from "../../config/site";
import LanguageSwitcher from "../ui/LanguageSwitcher.astro";
import type { Locale } from "../../i18n";
import type { Translations } from "../../i18n/types";
import { localePath } from "../../i18n";

interface Props {
  locale: Locale;
  t: Translations;
  alternateUrls: Record<Locale, string>;
}

const { locale, t, alternateUrls } = Astro.props;
---

<footer class="bg-dark text-gray-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col items-center text-center gap-6">
      <a href={locale === "de" ? "/" : `/${locale}/`}>
        <img src="/Logo_Yellow.png" alt={siteConfig.name} class="h-14" />
      </a>

      <a
        href={`tel:${siteConfig.phone}`}
        class="inline-flex items-center gap-2 rounded-full bg-taxi-400 px-6 py-3 text-base font-bold text-dark hover:bg-taxi-500 transition-colors"
      >
        <Phone class="h-5 w-5" />
        {siteConfig.phoneDisplay}
      </a>

      <LanguageSwitcher currentLocale={locale} alternateUrls={alternateUrls} />
    </div>

    <div class="mt-10 pt-8 border-t border-gray-800 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-gray-500">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. {t.footer.allRightsReserved}</p>
      <div class="flex gap-6">
        <a href={localePath(locale, t.routes.impressum)} class="hover:text-white transition-colors">{t.footer.impressum}</a>
        <a href={localePath(locale, t.routes.datenschutz)} class="hover:text-white transition-colors">{t.footer.datenschutz}</a>
      </div>
    </div>

    <div class="mt-4 text-center text-xs text-gray-600">
      <p>{t.footer.madeBy} <a href="https://digiwelle.de" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity" style="color: #D7FF2F;">digiwelle</a></p>
    </div>
  </div>
</footer>
